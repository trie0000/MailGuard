  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@kenjiuno/msgreader": "^1.28.0",
    "dompurify": "^3.1.0"
  }
}
