{
  "name": "mailguard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "メール誤送信検出ツール — .eml/.msg をドラッグするとAIで宛先と本文の矛盾をチェック",
  "scripts": {
    "dev": "node build.js --watch --serve",
