# MailGuard relay 用 環境変数の例
#
# このファイルを `.env` にリネームして使ってください (= start-relay.bat/sh が自動読み込み)。
#
# ★ 重要: API キー / 上流 URL / プロバイダ は **ブラウザの設定画面** から指定する
#         運用に変わったため、これらは env で設定しなくて OK。
#         env はあくまで「ブラウザ未設定時の fallback」と「relay 自体の起動設定」用。

# ─── relay 自体の設定 ─────────────────────────────────────────
# リッスン ポート (デフォルト 18100)
# MG_PORT=18100


# ─── ブラウザ未設定時の fallback (= 任意) ────────────────────
# 通常は不要。ブラウザ UI で設定するため。
# テスト用 / 共有運用で固定したい場合だけ設定。

# MG_PROVIDER=anthropic
# MG_PROVIDER=openai

# MG_UPSTREAM_BASE=https://api.anthropic.com
# MG_UPSTREAM_BASE=https://api.openai.com
# MG_UPSTREAM_BASE=https://<社内ゲートウェイ ホスト>

# MG_API_KEY=sk-ant-...
