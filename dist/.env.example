# ============================================================================
# MailGuard relay — 設定ファイル
# ============================================================================
#
# このファイルをコピーして `.env` (拡張子のみ) として保存し、自分の環境に
# 合わせて値を編集してください。
#
#   PowerShell:   Copy-Item .env.example .env
#   コマンド:     copy .env.example .env
#
# `.env` は .gitignore で除外されており、リポジトリにはコミットされません
# (秘密情報を安全に入れられます)。
#
# 形式: 1 行 1 設定、KEY=VALUE。コメントは `#` から行末まで。
# クォート (`"..."` / `'...'`) があれば自動で剥がします。
#
# 【配布時の使い方】
#   admin が組織共通の AI ゲートウェイ URL / deploy prefix / 自社ドメイン 等を
#   このファイルで設定して配布すると、利用者は初回起動時に自動でその値が
#   ブラウザ UI に seed されます (= API キーだけ自分で入れれば即動く)。
#   利用者が UI で値を変えればその変更が localStorage に保存されて env を上書き。
# ============================================================================

# ローカル listen ポート (既定 18100)
MAILGUARD_AI_PORT=18100

# 社内プロキシの URL (社内環境でのみ必要)
# 設定すると外部 AI API への通信が このプロキシ経由になります。
# 認証付きプロキシは Windows ログイン資格情報 (= NTLM/Negotiate) で
# 自動認証を試みます。
#MAILGUARD_AI_PROXY=http://onprem-proxy.example.com:8080

# 自己署名証明書を許容 (= 社内 MITM プロキシ環境用、本番禁止)
# 値を `1` にすると有効。TLS の検証をスキップするため、信頼できる経路でのみ使用。
#MAILGUARD_AI_SKIP_CERT_CHECK=0

# ─── 組織共通 AI デフォルト (= 配布時に admin が設定する想定) ──────
# これらの値は relay の GET /defaults エンドポイント経由で ブラウザに渡され、
# 利用者の初回起動時に localStorage に seed されます。
# 利用者が UI で値を変更すれば、その変更が env より優先されます (localStorage).
# 「env デフォルトに戻す」ボタンでいつでもここの値に再設定できます。

# プロバイダ ('claude' = Anthropic 直接 / 'corp' = Azure OpenAI 互換ゲートウェイ)
#MAILGUARD_AI_PROVIDER=corp

# 社内 AI ゲートウェイ URL (corp 選択時)
#MAILGUARD_AI_TARGET=https://gateway.example.com/myapi

# Azure OpenAI deployment 名のプレフィクス (corp 選択時)
# 利用者が選んだモデル名と組み合わせて deployment ID を組み立てる
# 例: prefix=spira- + model=gpt-4o-mini → spira-gpt-4o-mini
#MAILGUARD_AI_DEPLOY_PREFIX=spira-

# 既定モデル (corp / claude それぞれ独立)
#MAILGUARD_AI_CORP_MODEL=gpt-4o-mini
#MAILGUARD_AI_CLAUDE_MODEL=claude-sonnet-4-5

# 自社ドメイン (= 内部混入検出に使用、カンマ区切り)
#MAILGUARD_OWN_DOMAINS=example.co.jp,example.com

# 機密キーワード (= 本文出現 + 外部宛で high リスク、カンマ区切り)
# 設定しないと組込デフォルト (= 社外秘 / 機密 / マル秘 等) を使用
#MAILGUARD_INTERNAL_KEYWORDS=社外秘,機密,マル秘,人事評価

# ─── API キー (= 利用者が UI で個別に入力する想定なので通常 unset) ──
# 共有運用で固定したい場合だけ設定。設定すると relay が UI の API キーが
# 空のときに代わりに使用します (= UI に値があればそれが優先)。
# 注意: ここに書いたキーは relay が動く環境にいる全員が利用可能になります。
#MAILGUARD_AI_KEY=
